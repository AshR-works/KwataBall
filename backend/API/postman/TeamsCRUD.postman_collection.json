{
  "info": {
    "name": "Teams CRUD",
    "_postman_id": "teams-crud-collection",
    "description": "Collection pour tester le CRUD des équipes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Créer une équipe",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"FC KwataBall\",\n  \"shortName\": \"KWB\",\n  \"city\": \"Douala\",\n  \"foundedYear\": 2024,\n  \"logoUrl\": \"http://logo.png\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/auth/teams",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "teams"]
        }
      }
    },
    {
      "name": "Lister toutes les équipes",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/auth/teams",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "teams"]
        }
      }
    },
    {
      "name": "Récupérer une équipe par ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/auth/teams/:id",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "teams", ":id"]
        }
      }
    },
    {
      "name": "Mettre à jour une équipe",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"KwataBall United\",\n  \"city\": \"Yaoundé\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/auth/teams/:id",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "teams", ":id"]
        }
      }
    },
    {
      "name": "Supprimer une équipe",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:3000/auth/teams/:id/delete",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["auth", "teams", ":id", "delete"]
        }
      }
    }
  ]
}
